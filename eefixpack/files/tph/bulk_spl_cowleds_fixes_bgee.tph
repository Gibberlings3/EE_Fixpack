    bdamul06, itm, 1, 1, 146, spwi322, bdamu06d, 10 => bdamul06
    bdbow02, itm, 0, 0, 341, bdbow02, none, 10 => bdbow02
    bdclck03, itm, 0, 0, 232, bdclck03, none, 10 => bdclck03
